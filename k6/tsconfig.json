{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    // k6는 로컬 import에 .ts 확장자가 필수라, tsc가 이를 허용하도록 켠다 (noEmit 전제)
    "allowImportingTsExtensions": true,
    "types": ["k6"]
  },
  "include": ["scripts/**/*.ts"]
}
